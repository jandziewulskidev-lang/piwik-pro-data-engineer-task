# =============================================================================
# Python
# =============================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.python-version

# =============================================================================
# Environment variables - never commit secrets!
# =============================================================================
.env

# =============================================================================
# Data files - never commit raw or processed data
# Raw data belongs in S3/cloud storage in production
# =============================================================================
data/raw/
data/processed/

# =============================================================================
# DuckDB database files - generated by pipeline, not source code
# =============================================================================
*.duckdb
*.duckdb.wal

# =============================================================================
# dbt - generated artifacts, not source code
# =============================================================================
target/
dbt_packages/
logs/

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
